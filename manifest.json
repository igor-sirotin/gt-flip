{
  "manifest_version": 3,
  "name": "GT Flip",
  "version": "1.0.1",
  "description": "Automatically switches Google Translate target language to the opposite when the input language is detected.",
  "content_scripts": [
    {
      "matches": ["https://translate.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
